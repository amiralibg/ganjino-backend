PORT=3000
MONGODB_URI=mongodb://localhost:27017/ganjino
JWT_SECRET=your-secret-key-change-this-in-production
NODE_ENV=development

# Gold API Configuration
# Get your API key from https://BrsApi.ir
GOLD_API_KEY=your-gold-api-key-here
GOLD_API_URL=https://BrsApi.ir/Api/Market/Gold_Currency.php

# Optional comma-separated CORS allowlist in production
CORS_ORIGIN=http://localhost:8081,http://localhost:5174

# Seed defaults (used by `npm run seed:default`)
SEED_SUPER_ADMIN_EMAIL=superadmin@ganjino.local
SEED_SUPER_ADMIN_PASSWORD=SuperAdmin123!
SEED_SUPER_ADMIN_NAME=Ganjino Super Admin
SEED_ADMIN_EMAIL=admin@ganjino.local
SEED_ADMIN_PASSWORD=Admin123!
SEED_ADMIN_NAME=Ganjino Admin
